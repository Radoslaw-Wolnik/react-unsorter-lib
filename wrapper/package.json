{
  "name": "@radoslaw-wolnik/react-unsorter-lib",
  "version": "0.2.7-alpha",
  "repository": {
    "type": "git",
    "url": "https://github.com/Radoslaw-Wolnik/react-unsorter-lib.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "cd ../rust-unsorter && wasm-pack build --target bundler --out-dir ../wrapper/pkg",
    "build": "npm run build:wasm && tsc -p tsconfig.json",
    "clean": "rimraf dist pkg",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^6.0.3",
    "rimraf": "^6.0.0"
  },
  "keywords": [
    "wasm",
    "rust",
    "shuffle",
    "random"
  ],
  "license": "MIT"
}
