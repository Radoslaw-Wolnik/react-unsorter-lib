    "clean": "rimraf dist pkg",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^6.0.3",
    "rimraf": "^6.0.0"
  },
  "keywords": ["wasm", "rust", "shuffle", "random"],
