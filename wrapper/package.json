{
  "name": "react-unsorter-lib",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "cd ../rust-unsorter && wasm-pack build --target bundler --out-dir ../wrapper/pkg",
