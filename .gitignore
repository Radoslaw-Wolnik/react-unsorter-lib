# ==========================
# Rust (rust-unsorter)
# ==========================
/target/
**/*.rs.bk
Cargo.lock          # if you don't track dependencies; remove if you want deterministic builds
rust-unsorter/pkg/  # generated by wasm-pack

# ==========================
# Node / TypeScript (react-unsorter, demo-app)
# ==========================
node_modules/
dist/
build/
.wasm          # any local wasm copies
*.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================
# React / Vite specific
# ==========================
.vite/
*.local

# ==========================
# Environment & secrets
# ==========================
.env
.env.local
.env.*.local

# ==========================
# IDE / OS
# ==========================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==========================
# Optional: if you run wasm-pack inside react-unsorter
# ==========================
react-unsorter/wasm/   # if you copy/pkg here as part of build, ignore it (or keep if committed)
demo-app/wasm/